<Window x:Class="LuminaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Media Slideshow"
        Background="Black"
        WindowState="Maximized"
        WindowStyle="None"
        Cursor="None"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Dark ListBox style -->
        <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#440078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Button style -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1084D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#006CBC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Layer 0: Main media content -->
        <Grid x:Name="ContentGrid" Background="Black"
              MouseMove="Grid_MouseMove"
              MouseLeftButtonDown="Grid_MouseLeftButtonDown">

            <Image x:Name="ImageViewer"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>

            <MediaElement x:Name="VideoPlayer"
                          Stretch="Uniform"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          MediaEnded="VideoPlayer_MediaEnded"
                          Visibility="Collapsed"/>

            <ProgressBar x:Name="PlayProgressBar"
                         VerticalAlignment="Bottom"
                         HorizontalAlignment="Center"
                         Width="800"
                         Height="10"
                         Margin="0,0,0,20"
                         Minimum="0"
                         Maximum="100"
                         Foreground="#660078D4"
                         Background="#33FFFFFF"
                         BorderThickness="0"
                         Visibility="Collapsed"
                         MouseLeftButtonDown="PlayProgressBar_MouseLeftButtonDown"/>

            <!-- Empty state placeholder -->
            <TextBlock x:Name="EmptyStateText"
                       Text="No content found"
                       Foreground="#666666"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Layer 1: Playlist panel (right side) -->
        <Border x:Name="PlaylistPanel"
                HorizontalAlignment="Right"
                Width="280"
                Background="#E8111111"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="12,10" Background="#222222">
                    <Grid>
                        <TextBlock Text="Playlist"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PlaylistCountText"
                                   HorizontalAlignment="Right"
                                   Foreground="#888888"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- File list -->
                <ListBox x:Name="PlaylistListBox"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource DarkListBoxItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="PlaylistListBox_SelectionChanged"
                         VirtualizingPanel.IsVirtualizing="True">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TypeIcon}"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Width="20"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileName}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Footer hint -->
                <Border Grid.Row="2" Padding="12,6" Background="#1A1A1A">
                    <TextBlock Text="Del = move to trash"
                               Foreground="#666666"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Layer 2: Config panel overlay -->
        <Grid x:Name="ConfigOverlay" Visibility="Collapsed">
            <!-- Dim background -->
            <Border Background="#80000000"
                    MouseLeftButtonDown="ConfigOverlayBg_Click"/>

            <!-- Config form -->
            <Border Width="380"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="#FF1E1E1E"
                    CornerRadius="10"
                    Padding="28,24"
                    Effect="{x:Null}">
                <StackPanel>
                    <TextBlock Text="Settings"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <!-- Play Order -->
                    <TextBlock Text="Play Order"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="RandomOrderRadio"
                                     Content="Random"
                                     Foreground="White"
                                     IsChecked="True"
                                     GroupName="PlayOrder"
                                     Grid.Column="0"/>
                        <RadioButton x:Name="OriginalOrderRadio"
                                     Content="Original"
                                     Foreground="White"
                                     GroupName="PlayOrder"
                                     Grid.Column="1"/>
                    </Grid>

                    <!-- Include Subfolders -->
                    <CheckBox x:Name="SubfoldersCheckBox"
                              Content="Include Subfolders"
                              Foreground="White"
                              IsChecked="True"
                              Margin="0,0,0,16"/>

                    <!-- Image Duration -->
                    <Grid Margin="0,0,0,6">
                        <TextBlock Foreground="#AAAAAA" FontSize="12">
                            <Run Text="Image Display Duration: "/>
                            <Run x:Name="DurationValueText" Text="5"/>
                            <Run Text="s"/>
                        </TextBlock>
                    </Grid>
                    <Slider x:Name="DurationSlider"
                            Minimum="1"
                            Maximum="30"
                            Value="5"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            SmallChange="1"
                            LargeChange="5"
                            Margin="0,0,0,24"
                            ValueChanged="DurationSlider_ValueChanged"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply &amp; Close"
                                Style="{StaticResource AccentButton}"
                                Click="ConfigApply_Click"
                                Margin="0,0,8,0"/>
                        <Button Content="Cancel"
                                Style="{StaticResource DarkButton}"
                                Click="ConfigClose_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
