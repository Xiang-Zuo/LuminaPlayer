<Window x:Class="LuminaPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LuminaPlayer"
        Title="Media Slideshow"
        Background="Black"
        WindowState="Maximized"
        WindowStyle="None"
        Cursor="None"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <local:RatioConverter x:Key="RatioConverter"/>

        <!-- Dark ListBox style -->
        <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#440078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Button style -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent Button style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1084D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#006CBC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle arrow button style -->
        <Style x:Key="ToggleArrowButton" TargetType="Button">
            <Setter Property="Background" Value="#CC222222"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4,0,0,4" Padding="2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Root: 3-column layout — content | splitter | playlist -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
            <ColumnDefinition x:Name="PlaylistColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Main media content -->
        <Grid x:Name="ContentGrid" Grid.Column="0" Background="Black"
              MouseMove="Grid_MouseMove"
              MouseLeftButtonDown="Grid_MouseLeftButtonDown">

            <Image x:Name="ImageViewer"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>

            <MediaElement x:Name="VideoPlayer"
                          Stretch="Uniform"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          MediaEnded="VideoPlayer_MediaEnded"
                          Visibility="Collapsed"/>

            <ProgressBar x:Name="PlayProgressBar"
                         VerticalAlignment="Bottom"
                         HorizontalAlignment="Center"
                         Width="800"
                         Height="10"
                         Margin="0,0,0,20"
                         Minimum="0"
                         Maximum="100"
                         Foreground="#660078D4"
                         Background="#33FFFFFF"
                         BorderThickness="0"
                         Visibility="Collapsed"
                         MouseLeftButtonDown="PlayProgressBar_MouseLeftButtonDown"/>

            <!-- Empty state placeholder -->
            <TextBlock x:Name="EmptyStateText"
                       Text="No content found"
                       Foreground="#666666"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <!-- Delete indicator (top-left corner) -->
            <Border x:Name="DeleteIndicator"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="20,20"
                    Background="#AA000000"
                    CornerRadius="8"
                    Padding="14,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F5D1;"
                               FontSize="20"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Moved to trash"
                               Foreground="#CCCCCC"
                               FontSize="14"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Playlist toggle arrow (pinned to right edge) -->
            <Button x:Name="PlaylistToggleButton"
                    Style="{StaticResource ToggleArrowButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Height="60"
                    Click="PlaylistToggleButton_Click"
                    Content="&#x25C0;"/>
        </Grid>

        <!-- Column 1: Drag splitter (hidden when playlist closed) -->
        <GridSplitter x:Name="PlaylistSplitter"
                      Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="#333333"
                      Cursor="SizeWE"
                      Focusable="False"
                      Visibility="Collapsed"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Column 2: Playlist panel -->
        <Border x:Name="PlaylistPanel" Grid.Column="2"
                Background="#FF111111"
                MinWidth="200"
                MaxWidth="600"
                Visibility="Collapsed">
            <Grid Cursor="Arrow">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="14,12" Background="#222222">
                    <Grid>
                        <TextBlock Text="Playlist"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="PlaylistCountText"
                                   HorizontalAlignment="Right"
                                   Foreground="#888888"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- File list -->
                <ListBox x:Name="PlaylistListBox"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource DarkListBoxItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="PlaylistListBox_SelectionChanged"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.Resources>
                        <!-- Card template: thumbnail + label (for All / Images Only) -->
                        <DataTemplate x:Key="CardTemplate">
                            <StackPanel Margin="4">
                                <Border Background="#222222" CornerRadius="4"
                                        ClipToBounds="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Height"
                                                    Value="{Binding ActualWidth, RelativeSource={RelativeSource Self},
                                                            Converter={StaticResource RatioConverter}}"/>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="Uniform"/>
                                        <TextBlock Text="&#x25B6;"
                                                   FontSize="28"
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsVideo}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding DisplayLabel}"
                                           ToolTip="{Binding DisplayLabel}"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>

                        <!-- Compact template: single row button-like (for Videos Only) -->
                        <DataTemplate x:Key="CompactTemplate">
                            <Border Background="#282828" CornerRadius="4"
                                    Padding="10,8" Margin="2,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="&#x25B6;"
                                               FontSize="13"
                                               Foreground="#888888"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayLabel}"
                                               ToolTip="{Binding DisplayLabel}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.Resources>
                </ListBox>

                <!-- Footer hint -->
                <Border Grid.Row="2" Padding="14,8" Background="#1A1A1A">
                    <TextBlock Text="Del = move to trash  |  Drag edge to resize"
                               Foreground="#666666"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Config panel overlay (spans all columns, on top of everything) -->
        <Grid x:Name="ConfigOverlay" Grid.ColumnSpan="3"
              Visibility="Collapsed" Cursor="Arrow">
            <!-- Dim background -->
            <Border Background="#80000000"
                    MouseLeftButtonDown="ConfigOverlayBg_Click"/>

            <!-- Config form (1.5x bigger: 570px wide, larger fonts/padding) -->
            <Border Width="570"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="#FF1E1E1E"
                    CornerRadius="12"
                    Padding="42,36">
                <StackPanel>
                    <TextBlock Text="Settings"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,0,0,28"/>

                    <!-- Play Order -->
                    <TextBlock Text="Play Order"
                               Foreground="#AAAAAA"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="RandomOrderRadio"
                                     Content="Random"
                                     Foreground="White"
                                     FontSize="16"
                                     IsChecked="True"
                                     GroupName="PlayOrder"
                                     Grid.Column="0"/>
                        <RadioButton x:Name="OriginalOrderRadio"
                                     Content="Original"
                                     Foreground="White"
                                     FontSize="16"
                                     GroupName="PlayOrder"
                                     Grid.Column="1"/>
                    </Grid>

                    <!-- Include Subfolders -->
                    <CheckBox x:Name="SubfoldersCheckBox"
                              Content="Include Subfolders"
                              Foreground="White"
                              FontSize="16"
                              IsChecked="True"
                              Margin="0,0,0,24"/>

                    <!-- Source Type -->
                    <TextBlock Text="Source Type"
                               Foreground="#AAAAAA"
                               FontSize="16"
                               Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton x:Name="SourceAllRadio"
                                     Content="All"
                                     Foreground="White"
                                     FontSize="16"
                                     IsChecked="True"
                                     GroupName="SourceType"
                                     Grid.Column="0"/>
                        <RadioButton x:Name="SourceImageRadio"
                                     Content="Images Only"
                                     Foreground="White"
                                     FontSize="16"
                                     GroupName="SourceType"
                                     Grid.Column="1"/>
                        <RadioButton x:Name="SourceVideoRadio"
                                     Content="Videos Only"
                                     Foreground="White"
                                     FontSize="16"
                                     GroupName="SourceType"
                                     Grid.Column="2"/>
                    </Grid>

                    <!-- Image Duration -->
                    <Grid Margin="0,0,0,10">
                        <TextBlock Foreground="#AAAAAA" FontSize="16">
                            <Run Text="Image Display Duration: "/>
                            <Run x:Name="DurationValueText" Text="5"/>
                            <Run Text="s"/>
                        </TextBlock>
                    </Grid>
                    <Slider x:Name="DurationSlider"
                            Minimum="1"
                            Maximum="30"
                            Value="5"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            SmallChange="1"
                            LargeChange="5"
                            Margin="0,0,0,36"
                            ValueChanged="DurationSlider_ValueChanged"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Apply &amp; Close"
                                Style="{StaticResource AccentButton}"
                                Click="ConfigApply_Click"
                                Margin="0,0,12,0"/>
                        <Button Content="Cancel"
                                Style="{StaticResource DarkButton}"
                                Click="ConfigClose_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
